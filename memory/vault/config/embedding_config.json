{
  "provider": "openrouter",
  "model": "nomic-ai/nomic-embed-text-v1",
  "dimensions": 768,
  "cost_per_1k_tokens": 0.0001,
  "security": {
    "mode": "restricted",
    "allowed_agents": [
      "molty",
      "leonardo",
      "raphael"
    ]
  },
  "indexing": {
    "depth": "6-months",
    "refresh_interval": "daily"
  }
}
